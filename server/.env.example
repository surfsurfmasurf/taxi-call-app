# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taxi_app
DB_USER=postgres
DB_PASSWORD=your_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_REFRESH_EXPIRES_IN=30d

# PG (Payment Gateway) - 토스페이먼츠
TOSS_SECRET_KEY=test_sk_xxxxxxxxxxxxxxxx
TOSS_CLIENT_KEY=test_ck_xxxxxxxxxxxxxxxx
TOSS_API_URL=https://api.tosspayments.com/v1

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email

# SMS (OTP 인증)
SMS_API_KEY=your_sms_api_key
SMS_API_SECRET=your_sms_api_secret
SMS_SENDER_NUMBER=01012345678

# Map API
KAKAO_MAP_API_KEY=your_kakao_map_key
NAVER_MAP_CLIENT_ID=your_naver_map_id
NAVER_MAP_CLIENT_SECRET=your_naver_map_secret
